# =============================================================
# GAMA.VN — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------
# MongoDB Atlas (Database)
# -------------------------------------------------------
DATABASE_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# -------------------------------------------------------
# Payload CMS
# -------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
PAYLOAD_SECRET="your-secret-key-here"

# -------------------------------------------------------
# Vercel Blob Storage (for uploaded images in production)
# Get this from: Vercel Dashboard → Storage → Blob → your store → .env.local
# -------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# -------------------------------------------------------
# App URL (set automatically on Vercel)
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
