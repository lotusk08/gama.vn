# =============================================================
# GAMA.VN — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------
# MongoDB Atlas (Database)
# -------------------------------------------------------
DATABASE_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# -------------------------------------------------------
# Payload CMS Secret
# Generate with: openssl rand -base64 32
# Must be the same value across all environments.
# -------------------------------------------------------
PAYLOAD_SECRET="your-secret-key-here"

# -------------------------------------------------------
# Server URL
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
# -------------------------------------------------------
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# -------------------------------------------------------
# Vercel Blob Storage
# Set USE_VERCEL_BLOB=true ONLY in Vercel production environment.
# Locally: leave as false — uploads go to public/media/ instead.
# Get BLOB_READ_WRITE_TOKEN from:
#   Vercel Dashboard → Storage → Blob → your store → .env.local
# -------------------------------------------------------
USE_VERCEL_BLOB="false"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"
